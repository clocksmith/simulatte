{
  "name": "simulatte-world",
  "private": true,
  "scripts": {
    "test": "node --test tests/*.test.cjs",
    "train": "node tools/train.mjs",
    "serve": "node tools/serve-local.mjs",
    "review:server": "node tools/simulatte-review-server.mjs",
    "serve:static": "python3 -m http.server 4173 --bind 127.0.0.1 --directory public",
    "build:universe": "node tools/build-universe-index.mjs && node tools/build-affordance-index.mjs",
    "build:visual-cards": "node tools/build-visual-card-index.mjs",
    "audit:pipeline": "node tools/audit-pipeline-score.mjs",
    "audit:pipeline:baseline": "node tools/audit-pipeline-score.mjs --write-baseline",
    "audit:pipeline:summary": "node tools/summarize-pipeline-audit.mjs",
    "audit:pipeline:compare": "node tools/compare-pipeline-audit.mjs",
    "audit:catalogs": "node tools/audit-catalog-inventory.mjs",
    "audit:visual": "node tools/audit-intent-scene-screenshots.mjs --curated 4 --broad 4 --four 0 --eighty 0 --intent-mode model --timeout-ms 60000",
    "audit:visual:model": "node tools/audit-intent-scene-screenshots.mjs --curated 2 --broad 2 --four 0 --eighty 0 --intent-mode model --timeout-ms 45000",
    "eval:live": "node tools/audit-intent-scene-screenshots.mjs --url https://simulatte-world.web.app --curated 8 --broad 8 --four 0 --eighty 0 --intent-mode model --timeout-ms 60000 --out artifacts/live-visual-eval",
    "eval:live:summary": "node tools/summarize-live-visual-eval.mjs artifacts/live-visual-eval/report.json",
    "eval:live:model": "node tools/audit-intent-scene-screenshots.mjs --url https://simulatte-world.web.app --curated 4 --broad 4 --four 0 --eighty 0 --intent-mode model --timeout-ms 60000 --out artifacts/live-model-visual-eval",
    "validate:universe": "node tools/validate-semantic-universe.mjs",
    "validate:visual-cards": "node tools/validate-visual-card-index.mjs",
    "scan:determinism": "node tools/scan-nondeterminism.mjs",
    "stamp:build": "node tools/stamp-build.mjs",
    "benchmark:universe": "node tools/benchmark-semantic-coverage.mjs",
    "firebase:whoami": "firebase login:list && firebase use",
    "firebase:check": "firebase login:list && firebase use && firebase hosting:sites:list --project simulatte-world",
    "firebase:check:d4da": "firebase --account anthony@d4da.com hosting:sites:list --project simulatte-world",
    "firebase:check:personal": "firebase --account anthonyrobledo@gmail.com hosting:sites:list --project simulatte-world",
    "deploy:preview": "firebase hosting:channel:deploy preview --project simulatte-world",
    "deploy:preview:d4da": "firebase --account anthony@d4da.com hosting:channel:deploy preview --project simulatte-world",
    "deploy:preview:personal": "firebase --account anthonyrobledo@gmail.com hosting:channel:deploy preview --project simulatte-world",
    "deploy:hosting": "firebase deploy --only hosting --project simulatte-world",
    "deploy:hosting:d4da": "firebase --account anthony@d4da.com deploy --only hosting --project simulatte-world",
    "deploy:hosting:personal": "firebase --account anthonyrobledo@gmail.com deploy --only hosting --project simulatte-world"
  }
}
