{
  "name": "simulatte-world",
  "private": true,
  "scripts": {
    "test": "node --test tests/*.test.cjs",
    "serve": "node tools/serve-local.mjs",
    "serve:static": "python3 -m http.server 4173 --bind 127.0.0.1 --directory public",
    "build:universe": "node tools/build-universe-index.mjs && node tools/build-affordance-index.mjs",
    "build:visual-cards": "node tools/build-visual-card-index.mjs",
    "validate:universe": "node tools/validate-semantic-universe.mjs",
    "validate:visual-cards": "node tools/validate-visual-card-index.mjs",
    "scan:determinism": "node tools/scan-nondeterminism.mjs",
    "stamp:build": "node tools/stamp-build.mjs",
    "benchmark:universe": "node tools/benchmark-semantic-coverage.mjs",
    "firebase:whoami": "firebase login:list && firebase use",
    "firebase:check": "firebase login:list && firebase use && firebase hosting:sites:list --project simulatte-world",
    "deploy:preview": "firebase hosting:channel:deploy preview --project simulatte-world",
    "deploy:hosting": "firebase deploy --only hosting --project simulatte-world"
  }
}
