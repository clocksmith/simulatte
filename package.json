{
  "name": "simulatte-world",
  "private": true,
  "scripts": {
    "test": "node tools/run-test-files.mjs",
    "test:vendor-inference": "node tools/run-vendor-inference-lane.mjs",
    "samer:construction": "node tools/samer/run-construction-trial.mjs",
    "samer:construction:check": "node tools/samer/run-construction-trial.mjs --check",
    "samer:autonomy": "node tools/samer/autonomy/run-policy-trial.mjs",
    "samer:autonomy:check": "node tools/samer/autonomy/run-policy-trial.mjs --check",
    "check:autonomy": "node tools/autonomy/check-autonomy-data.mjs && npm run samer:autonomy:check",
    "autonomy:data:plan": "node tools/autonomy/manage-autonomy-data.mjs plan",
    "autonomy:data:fetch": "node tools/autonomy/manage-autonomy-data.mjs fetch",
    "autonomy:data:backfill": "node tools/autonomy/manage-autonomy-data.mjs backfill",
    "autonomy:data:verify": "node tools/autonomy/manage-autonomy-data.mjs verify",
    "build:autonomy:data": "node tools/autonomy/build-nyc-autonomy-world.mjs && node tools/autonomy/build-region-packs.mjs --activate && node tools/autonomy/build-public-navigation-missions.mjs && node tools/autonomy/evaluate-feature-reranker.mjs && node tools/autonomy/sync-autonomy-manifest.mjs",
    "eval:autonomy:reranker": "node tools/autonomy/evaluate-feature-reranker.mjs && node tools/autonomy/sync-autonomy-manifest.mjs",
    "audit:autonomy:browser": "node tools/autonomy/run-browser-smoke.mjs",
    "train": "node tools/train.mjs",
    "serve": "node tools/serve-local.mjs",
    "review:server": "node tools/simulatte-review-server.mjs",
    "serve:static": "python3 -m http.server 4173 --bind 127.0.0.1 --directory public",
    "build:universe": "node tools/build-universe-index.mjs && node tools/build-affordance-index.mjs",
    "build:visual-cards": "node tools/build-visual-card-index.mjs",
    "audit:pipeline": "node tools/audit-pipeline.mjs --intent-mode model --profile-dir artifacts/model-cache-profile",
    "audit:pipeline:local": "node tools/audit-pipeline.mjs --intent-mode local",
    "audit:pipeline:score": "node tools/audit-pipeline-score.mjs",
    "audit:pipeline:baseline": "node tools/audit-pipeline.mjs --intent-mode model --profile-dir artifacts/model-cache-profile --write-baseline",
    "audit:pipeline:summary": "node tools/summarize-pipeline-audit.mjs",
    "audit:pipeline:compare": "node tools/compare-pipeline-audit.mjs",
    "audit:catalogs": "node tools/audit-catalog-inventory.mjs",
    "audit:visual": "node tools/audit-intent-scene-screenshots.mjs --curated 4 --broad 4 --four 0 --eighty 0 --intent-mode model --timeout-ms 60000 --profile-dir artifacts/model-cache-profile",
    "audit:visual:model": "node tools/audit-intent-scene-screenshots.mjs --curated 2 --broad 2 --four 0 --eighty 0 --intent-mode model --timeout-ms 45000 --profile-dir artifacts/model-cache-profile",
    "audit:gold:visual": "node tools/audit-intent-scene-screenshots.mjs --curated 0 --broad 0 --four 0 --eighty 0 --gold-set tools/samer/simulatte-public-gold-v1.json --intent-mode model --timeout-ms 60000 --profile-dir artifacts/model-cache-profile --out artifacts/samer-gold-visual",
    "eval:place-resolution": "node tools/autonomy/evaluate-place-resolution.mjs",
    "build:place-embeddings": "node tools/autonomy/compile-place-embeddings.mjs",
    "check:place-embeddings": "node tools/autonomy/compile-place-embeddings.mjs --check",
    "eval:live": "node tools/audit-intent-scene-screenshots.mjs --url https://simulatte-world.web.app/blank/ --curated 8 --broad 8 --four 0 --eighty 0 --intent-mode model --timeout-ms 60000 --out artifacts/live-visual-eval",
    "eval:live:summary": "node tools/summarize-live-visual-eval.mjs artifacts/live-visual-eval/report.json",
    "eval:live:model": "node tools/audit-intent-scene-screenshots.mjs --url https://simulatte-world.web.app/blank/ --curated 4 --broad 4 --four 0 --eighty 0 --intent-mode model --timeout-ms 60000 --out artifacts/live-model-visual-eval",
    "validate:universe": "node tools/validate-semantic-universe.mjs",
    "validate:visual-cards": "node tools/validate-visual-card-index.mjs",
    "scan:determinism": "node tools/scan-nondeterminism.mjs",
    "stamp:build": "node tools/stamp-build.mjs",
    "sync:model-lock-references": "node tools/sync-model-runtime-lock-references.mjs --write",
    "check:model-lock-references": "node tools/sync-model-runtime-lock-references.mjs --check",
    "sync:doppler:development": "node tools/sync-doppler-development.mjs --write",
    "check:doppler:development": "node tools/sync-doppler-development.mjs --check",
    "check:model-lock": "npm run check:model-lock-references && node tools/check-model-runtime-lock.mjs && npm run check:doppler:development",
    "check:deploy": "npm run check:model-lock && node tools/check-deploy-surface.mjs && npm run check:autonomy",
    "benchmark:universe": "node tools/benchmark-semantic-coverage.mjs",
    "benchmark:reranker-frontier": "node tools/benchmark-reranker-frontier.mjs",
    "firebase:whoami": "firebase login:list && firebase use",
    "firebase:check": "firebase login:list && firebase use && firebase hosting:sites:list --project simulatte-world",
    "firebase:check:d4da": "firebase --account \"$SIMULATTE_FIREBASE_D4DA_ACCOUNT\" hosting:sites:list --project simulatte-world",
    "firebase:check:personal": "firebase --account \"$SIMULATTE_FIREBASE_PERSONAL_ACCOUNT\" hosting:sites:list --project simulatte-world",
    "deploy:preview": "firebase hosting:channel:deploy preview --project simulatte-world",
    "deploy:preview:d4da": "firebase --account \"$SIMULATTE_FIREBASE_D4DA_ACCOUNT\" hosting:channel:deploy preview --project simulatte-world",
    "deploy:preview:personal": "firebase --account \"$SIMULATTE_FIREBASE_PERSONAL_ACCOUNT\" hosting:channel:deploy preview --project simulatte-world",
    "deploy:hosting": "firebase deploy --only hosting --project simulatte-world",
    "deploy:hosting:d4da": "firebase --account \"$SIMULATTE_FIREBASE_D4DA_ACCOUNT\" deploy --only hosting --project simulatte-world",
    "deploy:hosting:personal": "firebase --account \"$SIMULATTE_FIREBASE_PERSONAL_ACCOUNT\" deploy --only hosting --project simulatte-world"
  }
}
