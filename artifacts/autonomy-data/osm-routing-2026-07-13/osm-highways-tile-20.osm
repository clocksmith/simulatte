  <tag k="addr:city" v="New York"/>
  <tag k="addr:housenumber" v="1"/>
  <tag k="addr:postcode" v="10002"/>
  <tag k="addr:state" v="NY"/>
  <tag k="addr:street" v="Clinton Street"/>
  <tag k="alt_name" v="Big-a Bite;Big a Bite;Big Bite"/>
  <tag k="amenity" v="restaurant"/>
  <tag k="contact:instagram" v="bigabite"/>
  <tag k="contact:yelp" v="https://yelp.com/biz/biga-bite-new-york-2"/>
  <tag k="cuisine" v="pizza"/>
  <tag k="description" v="Known for Roman-style pizzas, including extra-long pies up to 10 feet, and an innovative pizza omakase menu. Offers creative toppings, gluten-free options, and a lively, communal dining experience."/>
  <tag k="description:bn" v="রোমান-স্টাইলের পিজ্জার জন্য পরিচিত, যার মধ্যে রয়েছে ১০ ফুট পর্যন্ত লম্বা পিজ্জা এবং উদ্ভাবনী পিজ্জা ওমাকাসে মেনু। সৃজনশীল টপিং, গ্লুটেন-মুক্ত বিকল্প এবং প্রাণবন্ত, সামাজিক ডাইনিং অভিজ্ঞতা প্রদান করে।"/>
  <tag k="description:en" v="Known for Roman-style pizzas, including extra-long pies up to 10 feet, and an innovative pizza omakase menu. Offers creative toppings, gluten-free options, and a lively, communal dining experience."/>
  <tag k="description:es" v="Conocido por sus pizzas al estilo romano, incluyendo pizzas extra largas de hasta 10 pies, y un innovador menú de pizza omakase. Ofrece ingredientes creativos, opciones sin gluten y una experiencia de comedor animada y comunitaria."/>
  <tag k="description:ru" v="Известен римской пиццей, включая очень длинную пиццу до 10 футов, и инновационным меню пиццы омакасэ. Предлагает креативные начинки, безглютеновые опции и оживлённую, дружественную атмосферу для совместного ужина."/>
  <tag k="description:zh" v="以罗马式披萨闻名，包括最长可达10英尺的超长披萨和创新的披萨omakase菜单。提供创意配料、无麸质选择以及热闹的共享用餐体验。"/>
  <tag k="diet:gluten_free" v="yes"/>
  <tag k="diet:vegetarian" v="yes"/>
  <tag k="dog" v="yes"/>
  <tag k="email" v="reservations@bigabite.pizza"/>
  <tag k="level" v="0"/>
  <tag k="name" v="Biga Bite"/>
  <tag k="opening_hours" v="Mo-Sa 17:00-24:00; Su 17:00-23:00"/>
  <tag k="phone" v="+1-917-265-8453"/>
  <tag k="pizza:style" v="roman"/>
  <tag k="reservation" v="recommended"/>
  <tag k="takeaway" v="yes"/>
  <tag k="website" v="https://bigabite.pizza"/>
 </node>
