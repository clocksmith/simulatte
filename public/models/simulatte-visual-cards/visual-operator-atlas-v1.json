{
  "schema": "simulatte.visualOperatorAtlas.v1",
  "id": "simulatte-visual-operator-atlas-v1",
  "source": "handwritten-operator-graphics-basis",
  "description": "Reusable graphics atoms and operator-to-visual mappings for compiling VisualIR without scene-template buckets.",
  "categories": {
    "geometry": ["surface", "volume", "path", "instrument", "network", "terrain", "orbital", "organic"],
    "field": ["scalar", "vector", "pressure", "thermal", "gravity", "optical", "electromagnetic", "uncertainty"],
    "material": ["emissive", "transparent", "fluid", "granular", "metal", "biological", "instrument", "phase"],
    "process": ["transport", "front", "feedback", "fracture", "orbit", "reaction", "growth", "measurement"],
    "motion": ["particles", "trails", "pulses", "waves", "deformation", "vortices", "branching", "scan"],
    "camera": ["cutaway", "orbital", "microscopic", "map", "lab", "motion"]
  },
  "mappings": [
    {
      "id": "visual.operator.heat-transfer.v1",
      "matchTerms": ["heat_transfer", "thermal_gradient", "temperature", "cooling", "heating", "heat", "thermal", "lava", "steam"],
      "geometryAtoms": ["thermal-glow-gradient", "surface-phase-boundary", "volume-vapor-plume"],
      "fieldAtoms": ["heatmap-isobands", "thermal-vector-fan"],
      "materialAtoms": ["emissive-hot", "transparent-vapor"],
      "processAtoms": ["thermal-diffusion-front", "phase-change-boundary"],
      "motionAtoms": ["buoyant-rise", "heat-shimmer"],
      "cameraAtoms": ["cutaway-section-depth", "instrumented-lab-depth"],
      "receiptText": "Heat transfer becomes glow gradients, vapor volumes, phase edges, and thermal vectors."
    },
    {
      "id": "visual.operator.fluid-advection.v1",
      "matchTerms": ["flow", "water", "river", "wind", "coolant", "airflow", "velocity"],
      "geometryAtoms": ["ribbon-streamline", "transparent-flow-tube", "particle-tracer-swarm"],
