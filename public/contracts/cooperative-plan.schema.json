{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Simulatte cooperative plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "id", "scenarioId", "worldId", "policyId", "needId", "offerId", "intentRevisionId", "baselineCommitmentSha256", "state", "participantIds", "routes", "marginalBurden", "reliability", "hardGates", "authorizationParticipantIds", "searchComplete", "selectedBy"],
  "properties": {
    "schema": { "const": "simulatte.cooperativePlan.v1" },
    "id": { "type": "string" },
    "scenarioId": { "type": "string" },
    "worldId": { "type": "string" },
    "policyId": { "type": "string" },
    "needId": { "type": "string" },
    "offerId": { "type": "string" },
    "intentRevisionId": { "type": "string" },
    "baselineCommitmentSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "state": { "enum": ["candidate", "soft_hold", "mutually_authorized", "frozen_prefix", "executing", "settled", "expired", "revoked", "refused", "missed", "failed"] },
    "participantIds": { "type": "array", "minItems": 2, "items": { "type": "string" } },
    "routes": { "type": "object" },
    "marginalBurden": { "type": "object" },
    "reliability": { "type": "object" },
    "hardGates": { "type": "array", "minItems": 1 },
    "authorizationParticipantIds": { "type": "array", "items": { "type": "string" } },
    "searchComplete": { "type": "boolean" },
    "selectedBy": { "type": "string" }
  }
}
