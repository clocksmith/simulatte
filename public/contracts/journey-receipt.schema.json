{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Simulatte autonomy journey receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "mission", "identities", "events", "terminalState", "finalState", "settlement", "trace", "verification", "integrity"],
  "properties": {
    "schema": { "const": "simulatte.autonomyJourneyReceipt.v2" },
    "mission": { "type": "object" },
    "identities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["worldId", "worldContentVersion", "embodimentId", "policyId", "occurrenceCatalogId", "regionRegistryId", "regionCompositionId", "regionPackIds", "circuitId", "boundaryGeometrySha256"],
      "properties": {
        "worldId": { "type": "string" },
        "worldContentVersion": { "type": "string" },
        "embodimentId": { "type": "string" },
        "policyId": { "type": "string" },
        "occurrenceCatalogId": { "type": ["string", "null"] },
        "regionRegistryId": { "type": ["string", "null"] },
        "regionCompositionId": { "type": ["string", "null"] },
        "regionPackIds": { "type": "array", "items": { "type": "string" } },
        "circuitId": { "type": ["string", "null"] },
        "boundaryGeometrySha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["schema", "id", "tick", "kind", "sourceId", "evidence"],
        "properties": {
          "schema": { "const": "simulatte.autonomyEvent.v1" },
          "id": { "type": "string" },
          "tick": { "type": "integer", "minimum": 0 },
          "kind": { "type": "string" },
          "sourceId": { "type": ["string", "null"] },
          "evidence": { "type": ["object", "null"] }
        }
      }
    },
    "terminalState": { "type": "string", "minLength": 1 },
    "finalState": { "type": "object" },
    "settlement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "taskType", "terminationKind", "completionReason", "targetDistanceM", "targetLaps", "targetDurationSeconds", "actualDistanceM", "actualDurationSeconds", "distanceErrorM", "durationErrorSeconds", "exactTargetSettlement", "completedLaps", "finalPartialDistanceM", "finalSegmentId", "finalSegmentProgressM", "boundaryGeometrySha256"],
      "properties": {
        "schema": { "const": "simulatte.autonomyJourneySettlement.v1" },
        "taskType": { "enum": ["delivery", "loop"] },
        "terminationKind": { "enum": ["arrival", "distance", "laps", "duration"] },
        "completionReason": { "type": "string", "minLength": 1 },
        "targetDistanceM": { "type": ["number", "null"], "minimum": 0 },
        "targetLaps": { "type": ["integer", "null"], "minimum": 1 },
        "targetDurationSeconds": { "type": ["number", "null"], "minimum": 0 },
        "actualDistanceM": { "type": "number", "minimum": 0 },
        "actualDurationSeconds": { "type": "number", "minimum": 0 },
        "distanceErrorM": { "type": ["number", "null"] },
        "durationErrorSeconds": { "type": ["number", "null"] },
        "exactTargetSettlement": { "type": "boolean" },
        "completedLaps": { "type": "integer", "minimum": 0 },
        "finalPartialDistanceM": { "type": ["number", "null"], "minimum": 0 },
        "finalSegmentId": { "type": ["string", "null"] },
        "finalSegmentProgressM": { "type": "number", "minimum": 0 },
        "boundaryGeometrySha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "trace": { "type": "array", "items": { "type": "object" } },
    "verification": { "type": "object" },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "terminalHash", "entryCount"],
      "properties": {
        "algorithm": { "const": "sha256-canonical-json-chain-v1" },
        "terminalHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "entryCount": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
