{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Simulatte resource offer",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "id", "participantId", "intentId", "itemId", "quantity", "kind", "availableNodeId", "riskTier", "minimumCompensationCents", "consentState", "expiresAt"],
  "properties": {
    "schema": { "const": "simulatte.resourceOffer.v1" },
    "id": { "type": "string" },
    "participantId": { "type": "string" },
    "intentId": { "type": "string" },
    "itemId": { "type": "string" },
    "quantity": { "type": "integer", "minimum": 1 },
    "kind": { "enum": ["already_carried", "available_along_journey"] },
    "availableNodeId": { "type": "string" },
    "riskTier": { "type": "string" },
    "minimumCompensationCents": { "type": "number", "minimum": 0 },
    "consentState": { "enum": ["available", "revoked"] },
    "expiresAt": { "type": "string" }
  }
}
