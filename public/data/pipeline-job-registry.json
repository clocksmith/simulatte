{
  "$schema": "./pipeline-job-registry.schema.json",
  "schema": "simulatte.pipelineJobRegistry.v1",
  "id": "simulatte-shared-pipeline-jobs-v1",
  "jobs": [
    {
      "id": "runtime-preparation",
      "order": 1,
      "label": "Runtime preparation",
      "contract": "Prove every required runtime, governed asset, index, and optional model before work begins.",
      "sharedStrategies": [{ "id": "governed-runtime-bootstrap", "status": "required" }]
    },
    {
      "id": "understand-request",
      "order": 2,
      "label": "Understand request",
      "contract": "Convert source text into typed, source-bound language evidence without committing execution meaning.",
      "sharedStrategies": [{ "id": "deterministic-language-grammar", "status": "default" }]
    },
    {
      "id": "find-candidates",
      "order": 3,
      "label": "Find candidates",
      "contract": "Retrieve a bounded candidate frontier, rank it, and preserve refusal authority.",
      "sharedStrategies": [
        { "id": "deterministic-index-retrieval", "status": "default" },
        { "id": "qwen-embedding-retrieval", "status": "optional" },
        { "id": "deterministic-typed-reranking", "status": "default" }
      ]
    },
    {
      "id": "commit-meaning",
      "order": 4,
      "label": "Commit meaning",
      "contract": "Select grounded entities, relations, constraints, and obligations from receipted evidence.",
      "sharedStrategies": [{ "id": "typed-grounded-commitment", "status": "required" }]
    },
    {
      "id": "execute",
      "order": 5,
      "label": "Execute",
      "contract": "Compile and run the selected plan under deterministic constraints and explicit state transitions.",
      "sharedStrategies": []
    },
    {
      "id": "build-visuals",
      "order": 6,
      "label": "Build visuals",
      "contract": "Lower settled meaning and execution state into a bounded presentation or render contract.",
      "sharedStrategies": []
    },
    {
      "id": "render",
      "order": 7,
      "label": "Render",
      "contract": "Execute the presentation contract without inventing new semantic commitments.",
      "sharedStrategies": [{ "id": "webgpu-presentation", "status": "required" }]
    },
    {
      "id": "settle-proof",
      "order": 8,
      "label": "Settle proof",
      "contract": "Settle outcome obligations from execution receipts and add no new product content.",
      "sharedStrategies": [{ "id": "receipt-obligation-settlement", "status": "required" }]
    }
  ],
