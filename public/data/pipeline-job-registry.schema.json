{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "simulatte.pipelineJobRegistry.schema.v1",
  "title": "Simulatte Pipeline Job Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema", "id", "jobs", "strategies", "evidenceSources", "surfaces"],
  "properties": {
    "$schema": { "type": "string" },
    "schema": { "const": "simulatte.pipelineJobRegistry.v1" },
    "id": { "type": "string", "minLength": 1 },
    "jobs": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": { "$ref": "#/$defs/job" }
    },
    "strategies": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/strategy" }
    },
    "evidenceSources": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidenceSource" }
    },
    "surfaces": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "$ref": "#/$defs/surface" }
    }
  },
  "$defs": {
    "jobId": {
      "enum": [
        "runtime-preparation",
        "understand-request",
        "find-candidates",
        "commit-meaning",
        "execute",
        "build-visuals",
        "render",
        "settle-proof"
      ]
    },
    "job": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "order", "label", "contract", "sharedStrategies"],
      "properties": {
        "id": { "$ref": "#/$defs/jobId" },
        "order": { "type": "integer", "minimum": 1, "maximum": 8 },
        "label": { "type": "string", "minLength": 1 },
        "contract": { "type": "string", "minLength": 1 },
        "sharedStrategies": {
          "type": "array",
          "items": { "$ref": "#/$defs/strategySelection" }
        }
      }
    },
    "performanceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceId", "recordType", "recordId"],
      "properties": {
        "sourceId": { "type": "string", "minLength": 1 },
        "recordType": { "enum": ["candidate", "lane"] },
        "recordId": { "type": "string", "minLength": 1 }
      }
    },
    "strategy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "jobId", "label", "kind", "performanceRefs"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "jobId": { "$ref": "#/$defs/jobId" },
        "label": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["deterministic", "model", "runtime", "renderer"] },
        "modelLockPath": { "type": "string", "minLength": 1 },
        "performanceRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/performanceRef" }
        }
      }
    },
    "evidenceSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "path"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["frontier", "lane-diagnostic"] },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "strategySelection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "status": { "enum": ["required", "default", "optional", "fallback", "disabled", "evaluation-only"] }
      }
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["jobId", "phase", "boundary", "owners", "surfaceStrategies"],
      "properties": {
        "jobId": { "$ref": "#/$defs/jobId" },
        "phase": { "type": ["integer", "null"], "minimum": 1, "maximum": 8 },
        "boundary": { "type": "string", "minLength": 1 },
        "owners": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "surfaceStrategies": {
          "type": "array",
          "items": { "$ref": "#/$defs/strategySelection" }
        }
      }
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "route", "label", "bindings"],
      "properties": {
        "id": { "enum": ["autonomy", "blank"] },
        "route": { "enum": ["/", "/blank/"] },
        "label": { "type": "string", "minLength": 1 },
        "bindings": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": { "$ref": "#/$defs/binding" }
        }
      }
    }
  }
}
