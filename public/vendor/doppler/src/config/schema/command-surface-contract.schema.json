{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clocksmith.dev/doppler/schemas/command-surface-contract-v1.schema.json",
  "title": "Doppler Command Surface Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "source",
    "commands"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": 1
    },
    "source": {
      "const": "doppler"
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/command"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "commandId": {
      "enum": [
        "convert",
        "refresh-integrity",
        "debug",
        "bench",
        "verify",
        "lora",
        "distill",
        "diagnose"
      ]
    },
    "surface": {
      "enum": [
        "browser",
        "node"
      ]
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "surfaces",
        "cliUsageRequired",
        "reason"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/commandId"
        },
        "surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/surface"
          },
          "uniqueItems": true
        },
        "cliUsageRequired": {
          "type": "boolean"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
