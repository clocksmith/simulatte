{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clocksmith.dev/doppler/schemas/claim-evidence-contract-v1.schema.json",
  "title": "Doppler Claim Evidence Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "source",
    "releaseClaimPolicyPath",
    "benchmarkPolicyPath",
    "localInferenceClaimMatrixPath",
    "releaseMatrixPath",
    "goalMatrixPath",
    "requiredScripts",
    "requiredGoalEvidence",
    "requiredReleaseMatrixSources"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "schemaVersion": {
      "const": 1
    },
    "source": {
      "const": "doppler"
    },
    "releaseClaimPolicyPath": {
      "$ref": "#/$defs/repoRelativeJsonPath"
    },
    "benchmarkPolicyPath": {
      "$ref": "#/$defs/repoRelativeJsonPath"
    },
    "localInferenceClaimMatrixPath": {
      "$ref": "#/$defs/repoRelativeJsonPath"
    },
    "releaseMatrixPath": {
      "$ref": "#/$defs/repoRelativeJsonPath"
    },
    "goalMatrixPath": {
      "$ref": "#/$defs/repoRelativeJsonPath"
    },
    "requiredScripts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "requiredGoalEvidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/repoRelativeJsonPath"
      },
      "uniqueItems": true
    },
    "requiredReleaseMatrixSources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "repoRelativeJsonPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\.json$",
      "not": {
        "anyOf": [
          {
            "pattern": "^/"
          },
          {
            "pattern": "\\\\"
          },
          {
            "pattern": "(^|/)\\.\\.(/|$)"
          }
        ]
      }
    }
  }
}
