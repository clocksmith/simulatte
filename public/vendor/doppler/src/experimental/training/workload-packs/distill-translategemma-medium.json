{
  "schemaVersion": 1,
  "kind": "distill",
  "id": "distill-translategemma-medium",
  "description": "Deterministic medium translategemma distillation workload for JS checkpoint/eval/watch lanes.",
  "claimBoundary": "Practical deterministic distillation traceability for translation checkpoints and eval artifacts.",
  "seed": 1337,
  "baseModelId": "gemma-3-1b-it-q4k-ehf16-af32",
  "studentModelId": "gemma-3-1b-it-q4k-ehf16-af32",
  "teacherModelId": "translategemma-4b-it-q4k-ehf16-af32",
  "datasetId": "distill-en-es-toy",
  "datasetPath": "tests/fixtures/training/distill-en-es-toy.jsonl",
  "evalDatasets": [
    {
      "id": "distill-en-es-toy-eval",
      "datasetPath": "tests/fixtures/training/distill-en-es-toy.jsonl",
      "evalKind": "translation",
      "metrics": ["bleu", "chrf"],
      "decodePolicy": {
        "maxTokens": 24,
        "stopOnEos": true
      },
      "scoreboardColumns": ["bleu", "chrf"],
      "sourceLangs": ["en"],
      "targetLangs": ["es"],
      "pairAllowlist": ["en->es"]
    }
  ],
  "trainingSchemaVersion": 1,
  "checkpointEvery": 2,
  "selectionMetric": "bleu",
  "selectionGoal": "max",
  "surfaceSupport": "node",
  "training": {
    "optimizer": {
      "type": "adam",
      "lr": 0.00015,
      "beta1": 0.9,
      "beta2": 0.999,
      "eps": 1e-8,
      "weightDecay": 0,
      "scheduler": {
        "enabled": false,
        "type": "constant",
        "warmupSteps": 0,
        "stepSize": 1,
        "gamma": 1,
        "totalSteps": 8,
        "minLr": 0
      }
    },
    "batchSize": 1,
    "accumSteps": 1,
    "steps": 8,
    "precision": {
      "activations": "f16",
      "gradients": "f32",
      "loraParams": "f32"
    },
    "gradientClipping": {
      "maxNorm": 1
    }
  },
  "distill": {
    "stagePlan": [
      {
        "id": "stage_a",
        "trainingStage": "stage_a",
        "objective": "kd",
        "steps": 4,
        "checkpointEvery": 2,
        "selectionMetric": "bleu",
        "selectionGoal": "max",
        "evalSchedule": "on_checkpoint"
      },
      {
        "id": "stage_b",
        "trainingStage": "stage_b",
        "objective": "triplet",
        "steps": 4,
        "checkpointEvery": 2,
        "selectionMetric": "bleu",
        "selectionGoal": "max",
        "evalSchedule": "on_checkpoint"
      }
    ],
    "studentGraphMode": "transformer_full",
    "temperature": 1,
    "alphaKd": 1,
    "alphaCe": 0,
    "tripletMargin": 0.2,
    "sourceLangs": ["en"],
    "targetLangs": ["es"],
    "pairAllowlist": ["en->es"],
    "strictPairContract": true,
    "subsetSpec": {
      "id": "distill-en-es-toy-medium",
      "size": 6,
      "seed": 1337,
      "balanceBy": "pair"
    }
