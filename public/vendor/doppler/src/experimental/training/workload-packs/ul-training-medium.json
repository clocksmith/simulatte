{
  "schemaVersion": 1,
  "id": "ul-training-medium",
  "description": "Deterministic medium UL training workload for pre-release calibration.",
  "claimBoundary": "Practical UL workflow quality traceability.",
  "seed": 1337,
  "baseModelId": "training",
  "datasetId": "ul-training-medium",
  "datasetPath": "tests/fixtures/training/ul-tiny-ci-dataset.json",
  "evalDatasets": [],
  "trainingSchemaVersion": 1,
  "checkpointEvery": 1,
  "selectionMetric": "total_loss",
  "selectionGoal": "min",
  "surfaceSupport": "node",
  "benchRun": {
    "warmupRuns": 1,
    "timedRuns": 3
  },
  "trainingBenchSteps": 8,
  "training": {
    "optimizer": {
      "type": "adam",
      "lr": 0.0002,
      "beta1": 0.9,
      "beta2": 0.999,
      "eps": 1e-8,
      "weightDecay": 0,
      "scheduler": {
        "enabled": false,
        "type": "constant",
        "warmupSteps": 0,
        "stepSize": 1,
        "gamma": 1,
        "totalSteps": 8,
        "minLr": 0
      }
    },
    "batchSize": 1,
    "accumSteps": 1,
    "steps": 8,
    "precision": {
      "activations": "f16",
      "gradients": "f32",
      "loraParams": "f32"
    },
    "gradientClipping": {
      "maxNorm": 1
    }
  },
  "trainingTests": [
    "ul-stage1",
    "ul-stage2"
  ]
}
