{
  "schemaVersion": 1,
  "kind": "lora",
  "id": "lora-doppler-code-agent-tiny",
  "description": "Tiny Doppler/Reploid code-agent LoRA workload for JavaScript, JSON, WGSL, review, and harness traces.",
  "claimBoundary": "Operator workload shape for causal-LM LoRA adapter training on code-agent text-pair traces; not a model-quality claim.",
  "seed": 1337,
  "baseModelId": "qwen-3-5-0-8b-q4k-ehaf16",
  "studentModelId": null,
  "teacherModelId": "zai-org/GLM-5.2",
  "datasetId": "doppler-code-agent-sft-tiny",
  "datasetPath": "tests/fixtures/training/doppler-code-agent-sft-tiny.jsonl",
  "evalDatasets": [
    {
      "id": "doppler-agent-heldout-suite-tiny-eval",
      "datasetPath": "tests/fixtures/training/doppler-agent-heldout-suite-tiny.jsonl",
      "evalKind": "text_generation",
      "metrics": [
        "loss",
        "agent_heldout_gate"
      ],
      "decodePolicy": {
        "maxTokens": 320,
        "stopOnEos": true
      },
      "scoreboardColumns": [
        "loss",
        "baseline.loss",
        "qualityClaim.absoluteImprovement",
        "agentEval.passRate"
      ],
      "quality": {
        "baseline": "base_model",
        "requireImprovement": true,
        "minAbsoluteImprovement": 0,
        "minRelativeImprovement": 0
      },
      "sourceLangs": [],
      "targetLangs": [],
      "pairAllowlist": [],
      "agentEval": {
        "suiteId": "doppler-agent-heldout-v1",
        "categories": [
          "js_patching",
          "wgsl_review",
          "manifest_config_review",
          "reploid_vfs_status_tool_loop",
          "patch_applies",
          "no_hallucinated_files_tools"
        ],
        "minPassRate": 1,
        "requirePatchApplies": false,
        "requireNoHallucinatedFiles": true,
        "requireNoHallucinatedTools": true,
        "allowedFiles": [
          "src/experimental/training/workloads.js",
          "tests/config/training-workload-loader-v2.test.js",
          "src/gpu/kernels/matmul.js",
          "src/gpu/kernels/matmul.wgsl",
          "tests/kernels/matmul.test.js",
          "src/config/schema/manifest.schema.js",
          "src/converter/manifest-inference.js",
          "src/config/merge.js",
          "self/core/agent-loop.js",
          "self/core/vfs.js",
          "self/core/tool-runner.js",
          "tests/fixtures/training/agent-patch-targets/sample-tool-loop.js",
          "src/experimental/training/workload-packs/registry.json",
          "tools/verify-training-workload-packs.js"
        ],
        "allowedTools": [
          "rg",
          "node",
          "npm",
          "git",
          "exec_command",
          "apply_patch"
        ]
      }
    }
  ],
  "trainingSchemaVersion": 1,
  "checkpointEvery": 1,
  "selectionMetric": "loss",
  "selectionGoal": "min",
  "surfaceSupport": "node",
  "training": {
    "optimizer": {
      "type": "adamw",
      "lr": 0.0001,
      "beta1": 0.9,
      "beta2": 0.999,
      "eps": 1e-8,
      "weightDecay": 0,
      "scheduler": {
        "enabled": false,
        "type": "constant",
        "warmupSteps": 0,
        "stepSize": 1,
        "gamma": 1,
        "totalSteps": 1,
        "minLr": 0
      }
    },
    "batchSize": 1,
    "accumSteps": 1,
    "steps": 1,
    "precision": {
      "activations": "f16",
      "gradients": "f16",
      "loraParams": "f32"
    },
    "gradientClipping": {
      "maxNorm": 1
    }
  },
  "lora": {
    "datasetFormat": "text-pairs",
    "taskType": "text_generation",
    "maxLength": 512,
    "joinWith": "\n",
    "adapter": {
      "rank": 8,
      "alpha": 16,
      "dropout": 0,
      "targetModules": [
        "q_proj",
        "v_proj"
      ]
    },
    "freeze": {
      "encoder": false,
      "prior": false,
      "decoder": false,
      "base": true,
      "lora": false
    },
    "export": {
      "enabled": true,
      "atCheckpoints": false,
      "select": "final",
      "id": "doppler-code-agent-qwen35-08b-lora",
      "name": "Doppler Code Agent Qwen 3.5 0.8B LoRA",
      "format": "manifest_json"
    },
    "activation": {
      "enabled": false,
      "autoActivate": false,
      "smokePrompt": "Review this WGSL bounds-check patch."
    }
  }
}
