{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "simulatte.plugin.foodRecallUsConfig.v2",
  "title": "food-recall-us plugin configuration",
  "type": "object",
  "required": ["id", "defaultScenarioId", "scenarios"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "defaultScenarioId": { "type": "string" },
    "ensembleReplicates": { "type": "integer", "minimum": 1, "maximum": 4096 },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind", "label", "description", "seed", "commodityId", "hazardId", "originFacilityKind", "durationDays", "contamination", "detectionProfile", "defaultIntervention"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "kind": { "type": "string", "enum": ["synthetic", "historical", "user_supplied"] },
          "label": { "type": "string" },
          "description": { "type": "string" },
          "seed": { "type": "string" },
          "commodityId": { "type": "string" },
          "hazardId": { "type": "string" },
          "originFacilityKind": { "type": "string" },
          "durationDays": { "type": "integer", "minimum": 1 },
          "contamination": {
            "type": "object",
            "required": ["seededLots", "hazardStratum", "foodCategory"],
            "properties": {
              "seededLots": { "type": "integer", "minimum": 0 },
              "prevalence": { "type": "number", "minimum": 0, "maximum": 1 },
              "initialLog10CfuPerG": { "type": "number" },
              "presenceMg": { "type": "number", "minimum": 0 },
              "hazardStratum": { "type": "string" },
              "foodCategory": { "type": "string" }
            }
          },
          "coldChainFailure": {
            "type": "object",
            "properties": {
              "corridorStage": { "type": "string" },
              "repairHours": { "type": "number", "minimum": 0 },
              "ambientTempC": { "type": "number" }
            }
          },
          "detectionProfile": { "type": "string", "enum": ["accelerated", "baseline", "delayed"] },
          "defaultIntervention": {
            "type": "object",
            "required": ["type", "dayOffset", "depth", "scope"],
            "properties": {
              "type": { "type": "string" },
              "dayOffset": { "type": "integer", "minimum": 0 },
              "depth": { "type": "string", "enum": ["retail", "consumer"] },
              "scope": { "type": "string", "enum": ["lot", "facility"] }
            }
          }
        }
      }
    }
  }
}
