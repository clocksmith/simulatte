{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Maritime Trade Global configuration",
  "type": "object",
  "required": [
    "schema",
    "id",
    "defaultVesselClass",
    "defaultCorridor",
    "defaultScenarioId",
    "containerCount"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "const": "simulatte.plugin.maritimeTradeConfig.v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "defaultVesselClass": {
      "type": "string",
      "minLength": 1
    },
    "defaultCorridor": {
      "type": "string",
      "minLength": 1
    },
    "defaultScenarioId": {
      "type": "string",
      "minLength": 1
    },
    "containerCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100000
    }
  }
}
