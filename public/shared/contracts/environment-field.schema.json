{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Simulatte environment field",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "id", "worldId", "civilTime", "utcInstant", "sunModel", "buildingDatasetId", "azimuthDegrees", "elevationDegrees", "gridResolutionM", "computeImplementation", "counts", "segmentRows", "quality", "performance", "claimBoundary"],
  "properties": {
    "schema": { "const": "simulatte.environmentField.v1" },
    "id": { "type": "string", "minLength": 1 },
    "worldId": { "type": "string", "minLength": 1 },
    "civilTime": { "type": "string", "minLength": 1 },
    "utcInstant": { "type": "string", "minLength": 1 },
    "sunModel": { "type": "string", "minLength": 1 },
    "buildingDatasetId": { "type": "string", "minLength": 1 },
    "azimuthDegrees": { "type": "number", "minimum": 0, "exclusiveMaximum": 360 },
    "elevationDegrees": { "type": "number", "minimum": -90, "maximum": 90 },
    "gridResolutionM": { "type": "number", "exclusiveMinimum": 0 },
    "computeImplementation": { "type": "string", "minLength": 1 },
    "timeSampling": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "routeCandidateCount", "sampledInstantCount", "edgeCostModelId", "edgeCostModelVersion", "fifo"],
      "properties": {
        "method": { "type": "string", "minLength": 1 },
        "routeCandidateCount": { "type": "integer", "minimum": 1 },
        "sampledInstantCount": { "type": "integer", "minimum": 1 },
        "edgeCostModelId": { "type": "string", "minLength": 1 },
        "edgeCostModelVersion": { "type": "string", "minLength": 1 },
        "fifo": { "type": "boolean" }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["buildingCount", "segmentCount", "uniqueSegmentCount", "sampleCount", "unknownHeightCount", "unknownSampleCount", "nightSampleCount", "candidateBuildingChecks"],
      "properties": {
        "buildingCount": { "type": "integer", "minimum": 0 },
        "segmentCount": { "type": "integer", "minimum": 0 },
        "uniqueSegmentCount": { "type": "integer", "minimum": 0 },
        "sampleCount": { "type": "integer", "minimum": 0 },
        "unknownHeightCount": { "type": "integer", "minimum": 0 },
        "unknownSampleCount": { "type": "integer", "minimum": 0 },
        "nightSampleCount": { "type": "integer", "minimum": 0 },
        "candidateBuildingChecks": { "type": "integer", "minimum": 0 }
      }
    },
    "segmentRows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["segmentId", "travelSeconds", "directSunSeconds", "shadeSeconds", "unknownSeconds", "nightSeconds", "sampleCount", "directFraction", "shadeFraction", "unknownFraction", "nightFraction"],
        "properties": {
          "segmentId": { "type": "string", "minLength": 1 },
          "travelSeconds": { "type": "number", "minimum": 0 },
          "directSunSeconds": { "type": "number", "minimum": 0 },
          "shadeSeconds": { "type": "number", "minimum": 0 },
          "unknownSeconds": { "type": "number", "minimum": 0 },
          "nightSeconds": { "type": "number", "minimum": 0 },
          "sampleCount": { "type": "integer", "minimum": 1 },
          "directFraction": { "type": "number", "minimum": 0, "maximum": 1 },
          "shadeFraction": { "type": "number", "minimum": 0, "maximum": 1 },
          "unknownFraction": { "type": "number", "minimum": 0, "maximum": 1 },
          "nightFraction": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "quality": { "type": "object" },
    "performance": { "type": "object" },
    "claimBoundary": { "type": "string", "minLength": 1 }
  }
}
