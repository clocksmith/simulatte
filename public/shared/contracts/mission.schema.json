{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Simulatte autonomy mission",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "id",
    "sourceText",
    "parser",
    "capability",
    "embodimentId",
    "task",
    "originNodeId",
    "destinationNodeId",
    "grounding",
    "placeResolution",
    "constraints",
    "obligations",
    "economics",
    "seed"
  ],
  "properties": {
    "schema": { "const": "simulatte.autonomyMission.v3" },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "sourceText": { "type": "string", "minLength": 1 },
    "parser": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "version", "claimBoundary", "evidence"],
      "properties": {
        "kind": { "enum": ["deterministic_grounded_lexical", "governed_hybrid_place_resolution"] },
        "version": { "enum": ["simulatte.autonomyMissionParser.v3", "simulatte.autonomyMissionParser.v4"] },
        "claimBoundary": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["field", "value", "start", "end", "method", "groundedId", "canonicalValue", "editDistance"],
            "properties": {
              "field": { "enum": ["task", "mode", "origin", "destination", "waypoint", "circuit", "targetDistance", "targetLaps", "targetDuration", "boundaryKind", "lanePreference", "pedestrianYield", "streetAvoidance", "maximumDuration", "compensation", "departureTime", "arrivalDeadlineTime", "daylightOnly"] },
              "value": { "type": "string", "minLength": 1 },
              "start": { "type": "integer", "minimum": 0 },
              "end": { "type": "integer", "minimum": 1 },
              "method": { "enum": ["exact_lexical", "exact_world_label", "constrained_fuzzy_place", "qwen_embedding_cosine", "extended_damerau_place", "constrained_fuzzy_keyword", "unit_conversion", "currency_conversion", "clock_time_conversion", "lap_count_conversion", "exact_routed_street", "constrained_fuzzy_routed_street", "exact_world_street", "constrained_fuzzy_world_street"] },
              "groundedId": { "type": ["string", "null"] },
              "canonicalValue": { "type": ["string", "null"] },
              "editDistance": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "matrixSchema", "rowId", "embodimentKind", "embodimentId", "missionFamily", "terminationKind", "artifactIds", "circuitId"],
      "properties": {
        "schema": { "const": "simulatte.autonomyCapabilityReceipt.v1" },
        "matrixSchema": { "const": "simulatte.autonomyCapabilityMatrix.v1" },
        "rowId": { "type": "string", "minLength": 1 },
        "embodimentKind": { "enum": ["pedestrian", "bicycle", "scooter", "car"] },
        "embodimentId": { "type": "string", "minLength": 1 },
        "missionFamily": { "enum": ["delivery", "point_to_point", "closed_circuit"] },
        "terminationKind": { "enum": ["arrival", "distance", "laps", "duration"] },
        "artifactIds": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
        "circuitId": { "type": ["string", "null"] }
      }
    },
    "embodimentId": { "type": "string", "minLength": 1 },
    "task": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "payloadId", "stopNodeIds"],
          "properties": {
            "type": { "const": "delivery" },
            "payloadId": { "type": "string", "minLength": 1 },
            "stopNodeIds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "stopNodeIds"],
          "properties": {
            "type": { "const": "point_to_point" },
            "stopNodeIds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "circuitId", "gait", "termination"],
          "properties": {
            "type": { "const": "loop" },
            "circuitId": { "type": "string", "minLength": 1 },
            "gait": { "enum": ["run", "walk", "ride"] },
            "termination": {
              "oneOf": [
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["kind", "targetDistanceM", "requestedDistance"],
                  "properties": {
                    "kind": { "const": "distance" },
                    "targetDistanceM": { "type": "number", "exclusiveMinimum": 0 },
                    "requestedDistance": { "$ref": "#/$defs/requestedDistance" }
                  }
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["kind", "targetLaps", "targetDistanceM"],
                  "properties": {
                    "kind": { "const": "laps" },
                    "targetLaps": { "type": "integer", "minimum": 1 },
                    "targetDistanceM": { "type": "number", "exclusiveMinimum": 0 }
                  }
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["kind", "targetDurationSeconds", "requestedDuration"],
                  "properties": {
                    "kind": { "const": "duration" },
                    "targetDurationSeconds": { "type": "number", "exclusiveMinimum": 0 },
                    "requestedDuration": { "$ref": "#/$defs/requestedDuration" }
                  }
                }
              ]
            }
          }
        }
      ]
    },
    "originNodeId": { "type": "string", "minLength": 1 },
    "destinationNodeId": { "type": ["string", "null"] },
    "placeResolution": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema", "resolverId", "lane", "modelExecution", "roles"],
          "properties": {
            "schema": { "const": "simulatte.missionPlaceResolution.v1" },
            "resolverId": { "type": "string", "minLength": 1 },
            "lane": { "const": "hybrid_lexical_extended_typo_qwen_embedding" },
            "modelExecution": { "type": "boolean" },
            "roles": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["role", "outcome", "nodeId", "evidence"],
                "properties": {
                  "role": { "enum": ["origin", "destination"] },
                  "outcome": { "const": "resolve" },
                  "nodeId": { "type": "string", "minLength": 1 },
                  "evidence": { "type": "object" }
                }
              }
            }
          }
        }
      ]
    },
    "grounding": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["circuitId", "label", "nodeIds", "segmentIds", "circuitLengthM", "fullLapsBeforeFinalPartial", "finalPartialDistanceM", "source"],
          "properties": {
            "circuitId": { "type": "string", "minLength": 1 },
            "label": { "type": "string", "minLength": 1 },
            "nodeIds": { "type": "array", "minItems": 2, "items": { "type": "string" }, "uniqueItems": true },
            "segmentIds": { "type": "array", "minItems": 2, "items": { "type": "string" }, "uniqueItems": true },
            "circuitLengthM": { "type": "number", "exclusiveMinimum": 0 },
            "fullLapsBeforeFinalPartial": { "type": ["integer", "null"], "minimum": 0 },
            "finalPartialDistanceM": { "type": ["number", "null"], "minimum": 0 },
            "source": {
              "type": "object",
              "additionalProperties": false,
              "required": ["datasetId", "sourceRevision", "propertyId", "boundaryKind", "surfaceClaim", "geometryWgs84Sha256", "selectedRingWgs84Sha256", "memberCount", "selectedMemberIndex", "selectionMethod", "claimBoundary"],
              "properties": {
                "datasetId": { "type": "string", "minLength": 1 },
                "sourceRevision": { "type": "string", "minLength": 1 },
                "propertyId": { "type": "string", "minLength": 1 },
                "boundaryKind": { "type": "string", "minLength": 1 },
                "surfaceClaim": { "type": "string", "minLength": 1 },
                "geometryWgs84Sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                "selectedRingWgs84Sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                "memberCount": { "type": "integer", "minimum": 1 },
                "selectedMemberIndex": { "type": "integer", "minimum": 0 },
                "selectionMethod": { "type": "string", "minLength": 1 },
                "claimBoundary": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      ]
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lanePreference", "avoidStreetNames", "mustYieldToPedestrians", "mustObeySignals", "mustStayOnCircuit", "maximumSpeedMps", "maximumDurationSeconds", "departureLocalMinutes", "arrivalDeadlineLocalMinutes", "daylightOnly", "daylightWindowLocalMinutes"],
      "properties": {
        "lanePreference": { "enum": ["protected", "any"] },
        "avoidStreetNames": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "mustYieldToPedestrians": { "type": "boolean" },
        "mustObeySignals": { "type": "boolean" },
        "mustStayOnCircuit": { "type": "boolean" },
        "maximumSpeedMps": { "type": "number", "exclusiveMinimum": 0 },
        "maximumDurationSeconds": { "type": ["number", "null"], "exclusiveMinimum": 0 },
        "departureLocalMinutes": { "type": "integer", "minimum": 0, "maximum": 1439 },
        "arrivalDeadlineLocalMinutes": { "type": ["integer", "null"], "minimum": 0, "maximum": 1439 },
        "daylightOnly": { "type": "boolean" },
        "daylightWindowLocalMinutes": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "integer", "minimum": 0, "maximum": 1439 } }
      }
    },
    "obligations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "required"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["arrival", "payload_delivery", "ordered_stops", "signal_compliance", "pedestrian_yield", "lane_preference", "street_avoidance", "arrival_deadline", "daylight_window", "distance_target", "laps_target", "duration_target", "closed_loop", "boundary_adherence", "lap_accounting"] },
          "required": { "type": "boolean" }
        }
      }
    },
    "economics": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema", "currency", "amountCents", "basis", "match", "claimBoundary"],
          "properties": {
            "schema": { "const": "simulatte.missionEconomics.v1" },
            "currency": { "const": "USD" },
            "amountCents": { "type": "integer", "minimum": 1 },
            "basis": { "const": "declared_gross_compensation" },
            "match": { "type": "object" },
            "claimBoundary": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "seed": { "type": "integer", "minimum": 0 }
  },
  "$defs": {
    "requestedDistance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "unit", "metersPerUnit", "convertedMeters"],
      "properties": {
        "value": { "type": "number", "exclusiveMinimum": 0 },
        "unit": { "enum": ["foot", "meter", "kilometer", "mile"] },
        "metersPerUnit": { "type": "number", "exclusiveMinimum": 0 },
        "convertedMeters": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "requestedDuration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "unit", "secondsPerUnit", "convertedSeconds"],
      "properties": {
        "value": { "type": "number", "exclusiveMinimum": 0 },
        "unit": { "enum": ["second", "minute", "hour"] },
        "secondsPerUnit": { "type": "number", "exclusiveMinimum": 0 },
        "convertedSeconds": { "type": "number", "exclusiveMinimum": 0 }
      }
    }
  }
}
