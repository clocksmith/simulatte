{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Simulatte application profile v1",
  "type": "object",
  "required": ["schema", "id", "plugins", "routeObjective"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "simulatte.applicationProfile.v1" },
    "id": { "type": "string" },
    "defaultMissionText": { "type": "string", "minLength": 1 },
    "missionExamples": { "type": "array", "minItems": 2, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "camera": {
      "type": "object",
      "required": ["initialMode", "runMode"],
      "additionalProperties": false,
      "properties": {
        "initialMode": { "enum": ["follow", "bird", "top"] },
        "runMode": { "enum": ["follow", "bird", "top"] },
        "pluginId": { "type": "string", "minLength": 1 },
        "targetId": { "type": "string", "minLength": 1 }
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "configId"],
        "additionalProperties": false,
        "properties": { "id": { "type": "string" }, "configId": { "type": "string" } }
      }
    },
    "routeObjective": { "type": "object", "additionalProperties": { "type": "number", "minimum": 0 } }
  }
}
