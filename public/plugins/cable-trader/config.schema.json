{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cable Trader configuration v1",
  "type": "object",
  "required": ["schema", "id", "cableTypes", "hubs", "candidateJourneys", "inventory"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "simulatte.plugin.cableTraderConfig.v1" },
    "id": { "type": "string", "minLength": 1 },
    "cableTypes": {
      "type": "array", "minItems": 1, "maxItems": 128,
      "items": { "type": "object", "required": ["id", "label", "labels"], "additionalProperties": false, "properties": { "id": { "type": "string" }, "label": { "type": "string" }, "labels": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } } } }
    },
    "hubs": {
      "type": "array", "minItems": 1, "maxItems": 32,
      "items": { "type": "object", "required": ["id", "label", "nodeId"], "additionalProperties": false, "properties": { "id": { "type": "string" }, "label": { "type": "string" }, "nodeId": { "type": "string" } } }
    },
    "candidateJourneys": {
      "type": "array", "minItems": 1, "maxItems": 64,
      "items": { "type": "object", "required": ["id", "label", "originNodeId", "destinationNodeId", "kind", "speedMps", "phaseOffsetM"], "additionalProperties": false, "properties": { "id": { "type": "string" }, "label": { "type": "string" }, "originNodeId": { "type": "string" }, "destinationNodeId": { "type": "string" }, "kind": { "enum": ["pedestrian", "bicycle", "scooter", "car"] }, "speedMps": { "type": "number", "exclusiveMinimum": 0 }, "phaseOffsetM": { "type": "number", "minimum": 0 } } }
    },
    "inventory": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } }
  }
}
