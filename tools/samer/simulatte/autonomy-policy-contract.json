{
  "$schema": "./autonomy-policy-contract.schema.json",
  "schema": "simulatte.samerAutonomyContract.v1",
  "experimentId": "simulatte-autonomy-action-selection-v1",
  "recordedAt": "2026-07-13",
  "methodOwner": {
    "repository": "gamma",
    "path": "projects/samer/README.md"
  },
  "domainOwner": {
    "repository": "simulatte",
    "path": "tools/samer/autonomy/README.md"
  },
  "causalContract": {
    "intervention": "action_bet_selection_approach",
    "capability": "continuous_delivery_bike_navigation",
    "population": {
      "id": "simulatte-autonomy-public-navigation-v1",
      "kind": "public_diagnostic",
      "sha256": "1fd49c1d6f3fb14206f866493bde0c1207dc8da1a26053f1417f81a31fc4e410",
      "visibility": "development_visible",
      "promotionEligible": false,
      "contaminationStatus": "ineligible_by_design"
    },
    "hypothesis": "Evidence-scored selection improves safety-adjusted mission completion over progress-only and seeded eligible selection under the same proposer, safety gate, dynamics, scenarios, and tick budget.",
    "primaryMetric": {
      "id": "safetyAdjustedCompletionScore",
      "type": "derived_from_deterministic_trace",
      "direction": "maximize",
      "formula": "scenarioEvaluationPass ? 1 - (tickCount / maximumTicksPerJourney * 0.1) : 0",
      "range": [0, 1]
    },
    "blockingGuardrails": [
      "zero_safety_violations",
      "all_required_obligations_pass",
      "receipt_chain_verified",
      "deterministic_repetitions",
      "declared_budget_saturated",
      "scenario_expectations"
    ],
    "failureInSelection": "Any guardrail failure rejects the lane before primary-metric comparison. A public diagnostic winner is not promotion evidence."
  },
  "lanes": [
    { "id": "anchor", "role": "anchor", "selectionApproach": "progress_only", "seed": 17 },
    { "id": "targeted", "role": "targeted", "selectionApproach": "evidence_scored", "seed": 17 },
    { "id": "seeded_control", "role": "control", "selectionApproach": "seeded_eligible", "seed": 73 }
  ],
  "matchedOperationDetails": {
    "worldId": "nyc-training-corridor-v1",
    "embodimentId": "delivery-bike-v1",
    "basePolicyId": "bet-selector-v1",
    "missionParser": "simulatte.autonomyMissionParser.v2",
    "routePlanner": "a_star_v1",
    "rolloutModel": "deterministic_reference_rollout",
    "safetyGate": "simulatte.autonomySafetyGateReceipt.v1",
    "modelIdentity": null,
    "adapterIdentity": null,
    "runtimeSourcePaths": [
      "public/shared/contracts/contract-validator.js",
      "public/shared/contracts/data-contract-validator.js",
      "public/simulatte/mission/capability-matrix.js",
      "public/simulatte/mission/mission-compiler.js",
      "public/simulatte/world/ambient-actors.js",
      "public/simulatte/world/world-model.js",
      "public/simulatte/world/route-planner.js",
      "public/simulatte/world/region-pack-merger.js",
      "public/simulatte/runtime/canonical-receipts.js",
      "public/simulatte/runtime/feature-retrieval.js",
      "public/simulatte/runtime/occurrence-engine.js",
      "public/simulatte/runtime/observation-builder.js",
      "public/simulatte/runtime/reference-dynamics.js",
      "public/simulatte/runtime/bet-proposer.js",
      "public/simulatte/runtime/safety-gate.js",
      "public/simulatte/runtime/bet-selector.js",
      "public/simulatte/runtime/bet-settlement.js",
      "public/simulatte/runtime/autonomy-controller.js",
      "public/simulatte/verifier/journey-verifier.js",
      "tools/samer/simulatte/run-policy-trial.mjs"
    ],
    "candidateOrder": ["emergency_stop", "wait", "yield", "proceed", "accelerate", "reroute"],
    "evaluationOrder": "scenario_then_lane_then_repetition"
  },
  "budget": {
    "scenarioSetId": "simulatte-autonomy-public-navigation-v1",
    "scenarioCount": 4,
    "repetitionsPerLane": 2,
    "maximumTicksPerJourney": 180,
    "maximumCandidatesPerTick": 6,
    "maximumRuns": 24
  },
  "saturation": {
    "method": "isSaturated(history, budget)",
    "rule": "A journey is saturated when it reaches a terminal state or consumes maximumTicksPerJourney. A lane is saturated when every declared scenario and repetition has a terminal receipt.",
    "silentExtensionAllowed": false
  },
  "metrics": [
    { "id": "safetyAdjustedCompletionScore", "valueType": "number", "authority": "machine_adjudicated", "role": "primary" },
    { "id": "missionCompletionRate", "valueType": "rate", "authority": "machine_adjudicated", "role": "supporting" },
    { "id": "requiredObligationPassRate", "valueType": "rate", "authority": "machine_adjudicated", "role": "blocking" },
    { "id": "safetyViolationCount", "valueType": "count", "authority": "machine_adjudicated", "role": "blocking" },
    { "id": "meanTickCount", "valueType": "number", "authority": "machine_adjudicated", "role": "supporting" },
    { "id": "betWinRate", "valueType": "rate", "authority": "machine_adjudicated", "role": "supporting" }
  ],
  "labelAuthority": {
    "kind": "deterministic_trace_verifier",
    "owner": "public/simulatte/verifier/journey-verifier.js",
    "humanAdjudicationRequiredFor": ["physical_plausibility", "street_scene_legibility"]
  },
  "promotion": {
    "automaticPromotionAllowed": false,
    "sealedScenarioSetRequired": true,
    "physicalWorldClaimAllowed": false,
    "status": "diagnostic_only"
  }
}
